<% 
 const message = locals.isAuth ? `You havent written any posts yet` : 'To create new posts, you need to log in to your profile';
 const emoji = locals.isAuth ? '🤫' : '🤔';
%>

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>My posts</title>
    <link rel="stylesheet" href="/global.css">
    <link rel="stylesheet" href="/elements/header.css">
    <link rel="stylesheet" href="/elements/postCard.css">
    <link rel="stylesheet" href="/elements/posts-grid.css">
  </head>
  <body>
    <%- include("../partials/header") %>

    <main class="feed-container">
      
      <header class="feed-header">
        <h2 class="feed-header__title">My posts</h2>
        <p class="feed-header__subtitle">Share your secrets with others</p>
      </header>

        <div class="posts-grid <%= isEmpty ? 'posts-grid--empty' : '' %>">
          
          <% if (isEmpty) { %>

            <div class="empty-state-card">
              <div class="empty-state-card__icon"><%= emoji %></div>
              <p class="empty-state-card__message"><%= message %></p>
              <a 
                href="<%= locals.isAuth ? '/messages/new' : '/auth/log-in' %>" 
                class="btn btn--primary empty-state-card__btn"
              ><%= locals.isAuth ? 'Create New Post' : 'Log In' %>
              </a>
            </div>

          <% } else { %>
            
            <% posts.forEach(post => { %>
              <%- include("../partials/post", {post, isMyPost: true}) %>
            <% }) %>
            
          <% } %>

        </div>

    </main>
  </body>
</html>
