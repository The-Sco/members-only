<%
  const isMyPost = locals.currentUser.id === post.user_id;
  const fullName = locals.isMember ? `${post.first_name} ${post.last_name}` : "-";
  const username = locals.isMember ? post.username : "anon";
%>

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= post.title %></title>
  </head>
  <body>
    <%- include("../partials/header") %>
    <main class="page-container">
      <a href="#" onclick="history.back(); return false;" class="back-link">
        ← Back
      </a>
      <div class="single-post__header">
        <h2 class="single-post__title"><%= post.title %></h2>
        <div class="single-post__full-name">
          <span>
            <%= isMyPost ? (locals.currentUser.first_name + '' + locals.currentUser.last_name) : fullName %>
          </span>
        </div>
        <div class="single-post__username">
          @<%= isMyPost ? locals.currentUser.username : username %>
        </div>
        <div class="single-post__date">
          <span>
            <%= post.timestamp %>
          </span>
        </div>
      </div>
      <div class="single-post__content">
        <p class="single-post__text">
          <%= post.text %>
        </p>
      </div>
      <% if (isMyPost || locals.isAdmin) { %>
        <div class="single-post__actions">
          <form action="/messages/single<%= post.id %>/delete" method="post">
            <button type="submit" class="btn btn--danger" onclick="return confirm('Are you sure you want to delete this post?');">Delete</button>
          </form>
        </div>
      <% } %>
    </main>
  </body>
</html>
