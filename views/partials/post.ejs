<% 
  const fullName = (locals.isMember || locals.isMyPost) ? `${post.users.first_name} ${post.users.last_name}` : "-";
  const username = (locals.isMember || locals.isMyPost) ? post.users.username : "anon";
  const isAnon = username === 'anon';
%>

<article class="post-card <%= isAnon ? 'post-card--anon' : 'post-card--member' %>">
  
  <header class="post-card__header">
    <div class="post-card__author">
      <h4 class="post-card__fullname"><%= fullName %></h4>
      <span class="post-card__username">@<%= username %></span>
    </div>
    <span class="post-card__status" title="<%= isAnon ? 'Anonymous Guest' : 'Club Member' %>"></span>
  </header>
  
  <div class="post-card__content">
    <a href="/messages/single/<%= post.id %>" class="post-card__title-link">
      <h3 class="post-card__title"><%= post.title %></h3>
    </a>
    <p class="post-card__text"><%= post.text %></p>
  </div>

</article>