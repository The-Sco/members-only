<% const links = [ 
  {
    title: "Home",
    url: "/messages",
  },
  {
    title: "Join",
    url: "/join",
  },
  {
    title: "My posts",
    url: "/messages/me",
  },
  {
    title: "New post",
    url: "/messages/new",
  }
]; 
  const user = locals?.currentUser;
  const role = user?.isAdmin ? "Admin" : (user?.isMember ? "Member" : "Guest");
%>

<header class="page-header">
  <h1 class="page-header__logo">Secret</h1>
  <nav class="page-header__nav">
    <ul class="page-header__links-list">
      <% links.forEach(l => { %>
        <li class="page-header__link">
          <a href="<%= l.url %>"><%= l.title %></a>
        </li>
      <% }); %>
    </ul>
    <div class="page-header__actions">
      <% if (!locals.isAuth) { %>
        <a href="/auth/log-in" class="btn btn--primary">Log in</a>
        <a href="/auth/sign-up" class="btn btn--primary">Sign up</a>
        <% } else { %>
          <div class="page-header__user-info">
            <span class="page-header__username">@<%= locals.currentUser.username %></span>
            <span class="page-header__role"><%= role %></span>
          </div>
          <a href="/auth/log-out" class="btn btn--danger" onclick="return confirm('Are you sure you want to log out?');">Log out</a>
        <% } %>
      </div>
  </nav>
</header>
