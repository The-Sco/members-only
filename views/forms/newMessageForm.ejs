<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Create New Post | SecretClub</title>
    <link rel="stylesheet" href="/global.css">
    <link rel="stylesheet" href="/elements/header.css">
    <link rel="stylesheet" href="/forms/form.css">
  </head>
  <body>
    
    <%- include("../partials/header") %>

    <main class="auth-page-container">
      <div class="auth-card">
        
        <header class="auth-card__header">
          <h2 class="auth-card__title">Create New Post</h2>
          <p class="auth-card__subtitle">Share your secret thoughts with the club</p>
        </header>

        <form action="/messages/new" method="POST" class="auth-form">
          
          <div class="form-field <%= (locals.errors?.title) ? 'form-field--error' : '' %>">
            <label for="title" class="form-field__label">Title</label>
            <input type="text" name="title" id="title" value="<%= locals?.data?.title || '' %>" placeholder="What's on your mind?" autocomplete="off" required />
            <% if (locals.errors?.title) { %>
              <span class="form-field__error-text"><%= errors.title.msg %></span>
            <% } %>
          </div>

          <div class="form-field <%= (locals.errors?.text) ? 'form-field--error' : '' %>">
            <label for="text" class="form-field__label">Text</label>
            <textarea name="text" id="text" rows="6" placeholder="Type your secret here..." required><%= locals.data?.text || '' %></textarea>
            <% if (locals.errors?.text) { %>
              <span class="form-field__error-text"><%= errors.text.msg %></span>
            <% } %>
          </div>

          <div class="auth-form__actions">
            <button type="submit" class="btn btn--primary">Publish Secret</button>
          </div>

        </form>
      </div>
    </main>

  </body>
</html>