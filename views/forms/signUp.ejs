<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign up | SecretClub</title>
    <link rel="stylesheet" href="/global.css">
    <link rel="stylesheet" href="/elements/header.css">
    <link rel="stylesheet" href="/forms/form.css">
  </head>
  <body>
    
    <%- include("../partials/header") %>

    <main class="auth-page-container">
      <div class="auth-card">
        
        <header class="auth-card__header">
          <h2 class="auth-card__title">Create Account</h2>
          <p class="auth-card__subtitle">
            Already have an account? <a href="/auth/log-in" class="auth-card__link">Log in</a>
          </p>
        </header>

        <form action="/auth/sign-up" method="POST" class="auth-form">
          
          <div class="auth-form__row">
            <div class="form-field <%= (locals.errors?.first_name) ? 'form-field--error' : '' %>">
              <label for="first-name" class="form-field__label">First name</label>
              <input type="text" name="first_name" id="first-name" value="<%= locals?.data?.first_name || '' %>" required />
              <% if (locals.errors?.first_name) { %>
                <span class="form-field__error-text"><%= errors.first_name.msg %></span>
              <% } %>
            </div>

            <div class="form-field <%= (locals.errors?.last_name) ? 'form-field--error' : '' %>">
              <label for="last-name" class="form-field__label">Last name</label>
              <input type="text" name="last_name" id="last-name" value="<%= locals?.data?.last_name || '' %>" required />
              <% if (locals.errors?.last_name) { %>
                <span class="form-field__error-text"><%= errors.last_name.msg %></span>
              <% } %>
            </div>
          </div>

          <div class="form-field <%= (locals.errors?.username) ? 'form-field--error' : '' %>">
            <label for="username" class="form-field__label">Username</label>
            <input type="text" name="username" id="username" value="<%= locals?.data?.username || '' %>" required />
            <% if (locals.errors?.username) { %>
              <span class="form-field__error-text"><%= errors.username.msg %></span>
            <% } %>
          </div>

          <div class="form-field <%= (locals.errors?.password) ? 'form-field--error' : '' %>">
            <label for="password" class="form-field__label">Password</label>
            <input type="password" name="password" id="password" placeholder="••••••••" required />
            <% if (locals.errors?.password) { %>
              <span class="form-field__error-text"><%= errors.password.msg %></span>
            <% } %>
          </div>

          <div class="form-field <%= (locals.errors?.confirm_password) ? 'form-field--error' : '' %>">
            <label for="confirm-password" class="form-field__label">Confirm password</label>
            <input type="password" name="confirm_password" id="confirm-password" placeholder="••••••••" required />
            <% if (locals.errors?.confirm_password) { %>
              <span class="form-field__error-text"><%= errors.confirm_password.msg %></span>
            <% } %>
          </div>

          <div class="auth-form__actions">
            <button type="submit" class="btn btn--primary">Create Club Account</button>
          </div>

        </form>
      </div>
    </main>

  </body>
</html>